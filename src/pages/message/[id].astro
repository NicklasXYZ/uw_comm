---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import CategoryTag from '../../components/CategoryTag.astro';
import DetailValue from '../../components/DetailValue.astro';
import MetadataLink from '../../components/MetadataLink.astro';
import MethodPill from '../../components/MethodPill.astro';
import {
  asList,
  messages,
  messageTitle,
  type Message,
} from '../../data/messages';

export function getStaticPaths() {
  return messages.map((message) => ({
    params: { id: message.id },
    props: { message },
  }));
}

interface Props {
  message: Message;
}

const { message } = Astro.props as Props;
const title = messageTitle(message);
const detailRows = (
  [
    { title: 'Message Variations', values: asList(message.messageVariations), kind: 'text' },
    { title: 'Description', values: asList(message.description), kind: 'text' },
    { title: 'Meaning', values: asList(message.meaning), kind: 'text' },
    { title: 'Categorization', values: message.categories, kind: 'category' },
    { title: 'References', values: message.references, kind: 'reference' },
  ] satisfies Array<{ title: string; values: string[]; kind: 'text' | 'category' | 'reference' }>
).filter((row) => row.values.length > 0);
---

<StarlightPage
  frontmatter={{
    title,
    description: message.meaning || message.description || message.premise || title,
    tableOfContents: false,
  }}
>
  <article class="detail-page not-content">
    <a class="back-link" href="/">Catalogue</a>

    <header class="detail-header">
      <div class="detail-heading">
        <span class="detail-eyebrow">Message</span>
        <p class="detail-title">{title}</p>
        <div class="detail-chips" aria-label="Message metadata">
          <MethodPill method={message.type} />
          {message.categories.map((category) => (
            <CategoryTag category={category} display="label" />
          ))}
        </div>
      </div>
    </header>

    <dl class="detail-overview" aria-label="Communication overview">
      <div>
        <dt>Encoder</dt>
        <dd>
          <MetadataLink kind="actor" value={message.messageEncoder} />
        </dd>
      </div>
      <div>
        <dt>Decoder</dt>
        <dd>
          <MetadataLink kind="actor" value={message.messageDecoder} />
        </dd>
      </div>
      <div>
        <dt>Context</dt>
        <dd>
          <MetadataLink kind="context" value={message.spatialContext} />
          <span> / </span>
          <MetadataLink kind="context" value={message.temporalContext} />
        </dd>
      </div>
    </dl>

    {
      message.premise && (
        <div class="premise-box">
          <strong>Premise</strong>
          <p>{message.premise}</p>
        </div>
      )
    }

    <dl class="detail-list">
      {
        detailRows.map(({ title, values, kind }) => (
          <div>
            <dt>{title}</dt>
            <dd>
              {values.length > 1 ? (
                <ul class:list={[kind !== 'text' && 'linked-detail-list']}>
                  {values.map((value) => (
                    <li>
                      <DetailValue kind={kind} value={value} />
                    </li>
                  ))}
                </ul>
              ) : (
                <DetailValue kind={kind} value={values[0]} />
              )}
            </dd>
          </div>
        ))
      }
    </dl>
  </article>
</StarlightPage>
