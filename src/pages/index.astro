---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import {
  actorHref,
  categoryHref,
  categoryLabel,
  contextHref,
  dataUpdated,
  filterOptions,
  methodHref,
  messageCount,
  messages,
  messageTitle,
  searchText,
} from '../data/messages';

const description =
  'Browse documented underwater and surface communication messages by sender, receiver, context, communication method, and category.';
---

<StarlightPage
  frontmatter={{
    title: 'Catalogue',
    description,
  }}
>
  <section class="catalogue-page not-content" data-catalogue>
    <div class="catalogue-intro" aria-label="Catalogue overview">
      <p>
        Browse documented underwater and surface communication messages by actor, context, method,
        and source reference.
      </p>
      <a class="catalogue-intro-link" href="/about/">About the catalogue</a>
    </div>

    <form class="filter-panel" data-filters>
      <label class="search-field">
        <span>Search</span>
        <input
          type="search"
          name="search"
          autocomplete="off"
          data-search
          placeholder="OK, emergency, slate, AUV..."
        />
      </label>

      <div class="facet-grid">
        <details class="facet">
          <summary>Message Encoder</summary>
          <div class="facet-options">
            {
              filterOptions.encoders.map((option) => (
                <label>
                  <input type="checkbox" data-filter-group="encoder" value={option} checked />
                  <span>{option}</span>
                </label>
              ))
            }
          </div>
        </details>

        <details class="facet">
          <summary>Message Decoder</summary>
          <div class="facet-options">
            {
              filterOptions.decoders.map((option) => (
                <label>
                  <input type="checkbox" data-filter-group="decoder" value={option} checked />
                  <span>{option}</span>
                </label>
              ))
            }
          </div>
        </details>

        <details class="facet">
          <summary>Spatial Context</summary>
          <div class="facet-options">
            {
              filterOptions.spatialContexts.map((option) => (
                <label>
                  <input type="checkbox" data-filter-group="spatial" value={option} checked />
                  <span>{option}</span>
                </label>
              ))
            }
          </div>
        </details>

        <details class="facet">
          <summary>Temporal Context</summary>
          <div class="facet-options">
            {
              filterOptions.temporalContexts.map((option) => (
                <label>
                  <input type="checkbox" data-filter-group="temporal" value={option} checked />
                  <span>{option}</span>
                </label>
              ))
            }
          </div>
        </details>

        <details class="facet">
          <summary>Communication Method</summary>
          <div class="facet-options">
            {
              filterOptions.types.map((option) => (
                <label>
                  <input type="checkbox" data-filter-group="type" value={option} checked />
                  <span>{option}</span>
                </label>
              ))
            }
          </div>
        </details>

        <details class="facet">
          <summary>Category</summary>
          <div class="facet-options">
            {
              filterOptions.categories.map((option) => (
                <label>
                  <input type="checkbox" data-filter-group="category" value={option} checked />
                  <span>{categoryLabel(option)}</span>
                </label>
              ))
            }
          </div>
        </details>
      </div>

      <div class="filter-actions">
        <div class="filter-action-buttons" aria-label="Filter actions">
          <button type="button" class="secondary-button" data-select-all>Select all</button>
          <button type="button" class="secondary-button" data-reset>Reset</button>
        </div>
      </div>
    </form>

    <div class="catalogue-list-meta" aria-label="Catalogue results">
      <output data-result-count>{messageCount} messages</output>
      {dataUpdated && <span>Last updated {dataUpdated}</span>}
    </div>

    <div class="message-grid" data-message-list>
      {
        messages.map((message) => (
          <article
            class:list={[
              'message-card',
              message.categories[0] && `message-card-${message.categories[0].toLowerCase()}`,
            ]}
            data-message-card
            data-search={searchText(message)}
            data-encoder={message.messageEncoder}
            data-decoder={message.messageDecoder}
            data-spatial={message.spatialContext}
            data-temporal={message.temporalContext}
            data-type={message.type}
            data-category={message.categories.join('|')}
          >
            <div class="message-card-meta">
              <a
                class="method-pill"
                href={methodHref(message.type)}
                aria-label={`Read about ${message.type}`}
              >
                {message.type}
              </a>
              <div class="tag-row" aria-label="Categories">
                {message.categories.map((category) => (
                  <a
                    class:list={['tag', `tag-${category.toLowerCase()}`]}
                    href={categoryHref(category)}
                    title={categoryLabel(category)}
                    aria-label={`Read about ${categoryLabel(category)}`}
                  >
                    {category}
                  </a>
                ))}
              </div>
            </div>

            <a class="message-title" href={`/message/${message.id}/`}>{messageTitle(message)}</a>

            <div class="message-flow" aria-label="Communication path">
              <a
                class="metadata-link"
                href={actorHref(message.messageEncoder)}
                aria-label={`Read about ${message.messageEncoder} as message encoder or decoder`}
              >
                {message.messageEncoder}
              </a>
              <span aria-hidden="true">&rarr;</span>
              <a
                class="metadata-link"
                href={actorHref(message.messageDecoder)}
                aria-label={`Read about ${message.messageDecoder} as message encoder or decoder`}
              >
                {message.messageDecoder}
              </a>
            </div>

            <dl class="compact-details">
              <div>
                <dt>Context</dt>
                <dd>
                  <a
                    class="metadata-link"
                    href={contextHref(message.spatialContext)}
                    aria-label={`Read about ${message.spatialContext} context`}
                  >
                    {message.spatialContext}
                  </a>
                  <span> / </span>
                  <a
                    class="metadata-link"
                    href={contextHref(message.temporalContext)}
                    aria-label={`Read about ${message.temporalContext} context`}
                  >
                    {message.temporalContext}
                  </a>
                </dd>
              </div>
              <div>
                <dt>Method</dt>
                <dd>
                  <a
                    class="metadata-link"
                    href={methodHref(message.type)}
                    aria-label={`Read about ${message.type}`}
                  >
                    {message.type}
                  </a>
                </dd>
              </div>
            </dl>
          </article>
        ))
      }
    </div>
  </section>

  <script is:inline>
    const catalogue = document.querySelector('[data-catalogue]');
    const searchInput = catalogue?.querySelector('[data-search]');
    const cards = Array.from(catalogue?.querySelectorAll('[data-message-card]') ?? []);
    const resultCount = catalogue?.querySelector('[data-result-count]');
    const selectAllButton = catalogue?.querySelector('[data-select-all]');
    const resetButton = catalogue?.querySelector('[data-reset]');
    const groups = ['encoder', 'decoder', 'spatial', 'temporal', 'type', 'category'];

    function filterInputs() {
      return Array.from(catalogue.querySelectorAll('[data-filter-group]'));
    }

    function selectedValues(group) {
      return new Set(
        Array.from(catalogue.querySelectorAll(`[data-filter-group="${group}"]:checked`)).map(
          (input) => input.value
        )
      );
    }

    function matchesSingle(card, group, selected) {
      if (selected.size === 0) return false;
      return selected.has(card.dataset[group]);
    }

    function matchesList(card, group, selected) {
      if (selected.size === 0) return false;
      return (card.dataset[group] || '').split('|').some((value) => selected.has(value));
    }

    function applyFilters() {
      const query = searchInput.value.trim().toLowerCase();
      const selected = Object.fromEntries(groups.map((group) => [group, selectedValues(group)]));
      let visible = 0;

      for (const card of cards) {
        const matches =
          (!query || card.dataset.search.includes(query)) &&
          matchesSingle(card, 'encoder', selected.encoder) &&
          matchesSingle(card, 'decoder', selected.decoder) &&
          matchesSingle(card, 'spatial', selected.spatial) &&
          matchesSingle(card, 'temporal', selected.temporal) &&
          matchesSingle(card, 'type', selected.type) &&
          matchesList(card, 'category', selected.category);

        card.hidden = !matches;
        if (matches) visible += 1;
      }

      resultCount.value = `${visible} ${visible === 1 ? 'message' : 'messages'}`;

      const inputs = filterInputs();
      const selectedCount = inputs.filter((input) => input.checked).length;
      if (selectAllButton) selectAllButton.disabled = selectedCount === inputs.length;
    }

    function setAllFilters(checked) {
      filterInputs().forEach((input) => {
        input.checked = checked;
      });
      applyFilters();
    }

    catalogue?.addEventListener('input', applyFilters);
    selectAllButton?.addEventListener('click', () => setAllFilters(true));
    resetButton?.addEventListener('click', () => {
      searchInput.value = '';
      setAllFilters(true);
    });

    applyFilters();
  </script>
</StarlightPage>
