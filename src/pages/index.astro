---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import CategoryTag from '../components/CategoryTag.astro';
import MetadataLink from '../components/MetadataLink.astro';
import MethodPill from '../components/MethodPill.astro';
import {
  categoryLabel,
  dataUpdated,
  filterOptions,
  messageCount,
  messages,
  messageTitle,
  searchText,
} from '../data/messages';

const description =
  'Browse documented underwater and surface communication messages by sender, receiver, context, communication method, and category.';

const defaultFacetLabel = (option: string) => option;
const facetGroups = [
  {
    title: 'Message Encoder',
    filterGroup: 'encoder',
    options: filterOptions.encoders,
    label: defaultFacetLabel,
  },
  {
    title: 'Message Decoder',
    filterGroup: 'decoder',
    options: filterOptions.decoders,
    label: defaultFacetLabel,
  },
  {
    title: 'Spatial Context',
    filterGroup: 'spatial',
    options: filterOptions.spatialContexts,
    label: defaultFacetLabel,
  },
  {
    title: 'Temporal Context',
    filterGroup: 'temporal',
    options: filterOptions.temporalContexts,
    label: defaultFacetLabel,
  },
  {
    title: 'Communication Method',
    filterGroup: 'type',
    options: filterOptions.types,
    label: defaultFacetLabel,
  },
  {
    title: 'Category',
    filterGroup: 'category',
    options: filterOptions.categories,
    label: categoryLabel,
  },
];
---

<StarlightPage
  frontmatter={{
    title: 'Catalogue',
    description,
    tableOfContents: true,
  }}
>
  <section
    class="catalogue-page not-content"
    data-catalogue
    data-filter-groups={facetGroups.map(({ filterGroup }) => filterGroup).join(' ')}
  >
    <div class="catalogue-intro" aria-label="Catalogue overview">
      <p>
        Browse documented underwater and surface communication messages by actor, context, method,
        and source reference.
      </p>
      <a class="catalogue-intro-link" href="/about/">About the catalogue</a>
    </div>

    <form class="filter-panel" data-filters>
      <label class="search-field">
        <span>Search</span>
        <input
          type="search"
          name="search"
          autocomplete="off"
          data-search
          placeholder="OK, emergency, slate, AUV..."
        />
      </label>

      <div class="facet-grid">
        {
          facetGroups.map(({ title, filterGroup, options, label }) => (
            <details class="facet">
              <summary>{title}</summary>
              <div class="facet-options">
                {options.map((option) => (
                  <label>
                    <input type="checkbox" data-filter-group={filterGroup} value={option} checked />
                    <span>{label(option)}</span>
                  </label>
                ))}
              </div>
            </details>
          ))
        }
      </div>

      <div class="filter-actions">
        <div class="filter-action-buttons" aria-label="Filter actions">
          <button type="button" class="secondary-button" data-select-all>Select all</button>
          <button type="button" class="secondary-button" data-reset>Reset</button>
        </div>
      </div>
    </form>

    <div class="catalogue-list-meta" aria-label="Catalogue results">
      <output data-result-count>{messageCount} messages</output>
      {dataUpdated && <span>Last updated {dataUpdated}</span>}
    </div>

    <div class="message-grid">
      {
        messages.map((message) => (
          <article
            class="message-card"
            data-message-card
            data-search={searchText(message)}
            data-encoder={message.messageEncoder}
            data-decoder={message.messageDecoder}
            data-spatial={message.spatialContext}
            data-temporal={message.temporalContext}
            data-type={message.type}
            data-category={message.categories.join('|')}
          >
            <div class="message-card-meta">
              <MethodPill method={message.type} />
              <div class="tag-row" aria-label="Categories">
                {message.categories.map((category) => (
                  <CategoryTag category={category} />
                ))}
              </div>
            </div>

            <a class="message-title" href={`/message/${message.id}/`}>{messageTitle(message)}</a>

            <div class="message-flow" aria-label="Communication path">
              <MetadataLink kind="actor" value={message.messageEncoder} />
              <span aria-hidden="true">&rarr;</span>
              <MetadataLink kind="actor" value={message.messageDecoder} />
            </div>

            <dl class="compact-details">
              <div>
                <dt>Context</dt>
                <dd>
                  <MetadataLink kind="context" value={message.spatialContext} />
                  <span> / </span>
                  <MetadataLink kind="context" value={message.temporalContext} />
                </dd>
              </div>
              <div>
                <dt>Method</dt>
                <dd>
                  <MetadataLink kind="method" value={message.type} />
                </dd>
              </div>
            </dl>
          </article>
        ))
      }
    </div>
  </section>

  <script is:inline>
    const catalogue = document.querySelector('[data-catalogue]');
    const searchInput = catalogue?.querySelector('[data-search]');
    const cards = Array.from(catalogue?.querySelectorAll('[data-message-card]') ?? []);
    const resultCount = catalogue?.querySelector('[data-result-count]');
    const selectAllButton = catalogue?.querySelector('[data-select-all]');
    const resetButton = catalogue?.querySelector('[data-reset]');
    const groups = (catalogue?.dataset.filterGroups ?? '').split(' ').filter(Boolean);
    const listGroups = new Set(['category']);

    function filterInputs() {
      return Array.from(catalogue?.querySelectorAll('[data-filter-group]') ?? []);
    }

    function selectedValues(group) {
      return new Set(
        Array.from(catalogue?.querySelectorAll(`[data-filter-group="${group}"]:checked`) ?? []).map(
          (input) => input.value
        )
      );
    }

    function matchesSingle(card, group, selected) {
      if (selected.size === 0) return false;
      return selected.has(card.dataset[group]);
    }

    function matchesList(card, group, selected) {
      if (selected.size === 0) return false;
      return (card.dataset[group] || '').split('|').some((value) => selected.has(value));
    }

    function applyFilters() {
      if (!searchInput || !resultCount) return;

      const query = searchInput.value.trim().toLowerCase();
      const selected = Object.fromEntries(groups.map((group) => [group, selectedValues(group)]));
      let visible = 0;

      for (const card of cards) {
        const matchesFilters = groups.every((group) =>
          listGroups.has(group)
            ? matchesList(card, group, selected[group])
            : matchesSingle(card, group, selected[group])
        );
        const matches =
          (!query || (card.dataset.search || '').includes(query)) && matchesFilters;

        card.hidden = !matches;
        if (matches) visible += 1;
      }

      resultCount.value = `${visible} ${visible === 1 ? 'message' : 'messages'}`;

      const inputs = filterInputs();
      const selectedCount = inputs.filter((input) => input.checked).length;
      if (selectAllButton) selectAllButton.disabled = selectedCount === inputs.length;
    }

    function setAllFilters(checked) {
      filterInputs().forEach((input) => {
        input.checked = checked;
      });
      applyFilters();
    }

    catalogue?.addEventListener('input', applyFilters);
    catalogue?.querySelector('[data-filters]')?.addEventListener('submit', (event) => {
      event.preventDefault();
    });
    selectAllButton?.addEventListener('click', () => setAllFilters(true));
    resetButton?.addEventListener('click', () => {
      if (searchInput) searchInput.value = '';
      setAllFilters(true);
    });

    applyFilters();
  </script>
</StarlightPage>
